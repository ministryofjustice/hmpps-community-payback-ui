{% extends "../layout.njk" %}

{% from "../../../components/sortableTable/macro.njk" import sortableTable %}
{%- from "moj/components/pagination/macro.njk" import mojPagination -%}

{% set pageTitle = 'Adjust travel time' %}

{% block content %}
{% if successMessages %}
  {% for message in successMessages %}
    {{ govukNotificationBanner({
          html: '<h3 class="govuk-!-margin-top-2">' + message + '</h3>',
          type: 'success',
          titleId: 'success-title-' + loop.index
        }) }}
    {% endfor %}
  {% endif %}
  <h1 class="govuk-heading-l" data-qa="page-title">{{ pageTitle }}</h1>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <form action="{{ paths.appointments.travelTime.filter() }}" method="get">

        <div class="search-and-filter"  data-module="cpb-team-filter">
          <h2 class="govuk-heading-m">Filter appointments</h2>
          {% if form.providerItems %}
            <div class="search-and-filter__row">
              {% include "../../../partials/teamFilter/_providerInput.njk" %}
            </div>
          {% else %}
            <label class="govuk-label govuk-label--s">Region</label>
            <input type="hidden" value="{{ form.provider.value }}" name="provider" />
            <p class="govuk-body">{{ form.provider.text }}</p>
          {% endif %}

          <div class="search-and-filter__row">
            <div class="govuk-button-group govuk-!-margin-bottom-0 govuk-!-margin-top-3">
                {{ govukButton({
                  "text": "Apply filters",
                  preventDoubleClick: true
                }) }}

                <a
                  href="{{ paths.appointments.travelTime.index() }}"
                  class="govuk-link govuk-!-margin-bottom-0"
                >
                  Clear
                </a>
              </div>
          </div>
        </div>

      </form>
    </div>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% if rows | length %}
        <div id="search-results">
          {{ sortableTable({
            head: tableHeaders,
            rows: rows
          }) }}
        </div>
      {% endif %}

      {% if totalPages and totalPages > 1 %}
        {{ mojPagination(paginationComponentParams(pageNumber, totalPages, totalElements, pageSize, hrefPrefix))}}
      {% endif %}

    </div>
  </div>
{% endblock %}
