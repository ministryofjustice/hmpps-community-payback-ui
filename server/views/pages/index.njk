{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName %}
{% set mainClasses = "app-container govuk-body" %}
{% set bodyClasses = "dashboard--index" %}

{% block content %}

  <h1>Record attendance on community payback</h1>

  <div class="card-container">
    <div class="card"  data-cy-card-section="track-progress-group-placements">
      <div class="card-body">
        <h2 class="govuk-heading-s">
          <a class="govuk-link" href="{{ paths.sessions.index() }}">Record group session attendance</a>
        </h2>
        <p class="govuk-body">Find a group session and record attendance outcomes</p>
      </div>
    </div>
     <div class="card"  data-cy-card-section="track-progress-individual-placements">
      <div class="card-body">
        <h2 class="govuk-heading-s">
          <a class="govuk-link" href="{{ paths.projects.index() }}">Record attendance with host partners</a>
        </h2>
        <p class="govuk-body">Find individual or group placements with a Host Partner and record attendance outcomes</p>
      </div>
    </div>
    <div class="card" data-cy-card-section="process-course-completions">
      <div class="card-body">
        <h2 class="govuk-heading-s">
          <a class="govuk-link" href="{{ paths.courseCompletions.index() }}">Record Community Campus hours</a>
        </h2>
        <p class="govuk-body">View course completions from Community Campus and record completed hours</p>
      </div>
    </div>
    <div class="card" data-cy-card-section="process-course-completions">
      <div class="card-body">
        <h2 class="govuk-heading-s">
          <a class="govuk-link" href="{{ paths.appointments.adjustTravelTime() }}">Adjust travel time hours</a>
        </h2>
        <p class="govuk-body">View attended appointments and record an adjustment for travel time</p>
      </div>
    </div>
  </div>

{% endblock %}
